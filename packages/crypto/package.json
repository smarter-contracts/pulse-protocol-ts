{
  "name": "@pulse-protocol/crypto",
  "version": "0.1.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --out-dir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noble/ciphers": "^1.0.0",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "@noble/post-quantum": "^0.2.0",
    "@pulse-protocol/types": "workspace:*",
    "@scure/bip32": "^1.4.0"
  },
  "devDependencies": {
    "@pulse-protocol/ipfs": "workspace:*",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
